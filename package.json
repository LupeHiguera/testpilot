{
  "name": "testpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "testpilot": "./dist/cli/index.js"
  },
  "scripts": {
    "testpilot": "tsx src/cli/index.ts",
    "demo:app": "vite --host 127.0.0.1",
    "serve": "tsx src/cli/index.ts serve",
    "ui:dev": "vite --config ui/vite.config.ts",
    "ui:build": "vite build --config ui/vite.config.ts",
    "build": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "validate": "npm run build && npm run test",
    "validate:demo": "npm run validate && npm run testpilot -- demo --mode mock",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@playwright/test": "^1.53.0",
    "@vitejs/plugin-react": "^4.5.0",
    "commander": "^13.1.0",
    "openai": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.4",
    "vite": "^6.3.5",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
